filters:
  and:
    - note.type == "swarm-service"
    - note.external_access == true
views:
  - type: table
    name: External Services
    order:
      - file.name
      - service_name
      - service_status
      - vm
      - port
      - traefik_entrypoint
      - url_external
      - url_internal
      - zfs_dataset
      - last_updated
    sort:
      - property: service_name
        direction: ASC
